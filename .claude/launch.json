{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Python HTTP Server (Port 8000)",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "8000"],
      "port": 8000
    },
    {
      "name": "Python HTTP Server (Port 3000)",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "3000"],
      "port": 3000
    },
    {
      "name": "Node.js HTTP Server (Port 8000)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", ".", "-p", "8000"],
      "port": 8000
    },
    {
      "name": "Node.js HTTP Server (Port 3000)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", ".", "-p", "3000"],
      "port": 3000
    }
  ]
}
